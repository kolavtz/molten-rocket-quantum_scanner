# sql_server_url_with_port=localhost:3306
# sql_user=change-me
# sql_password=change-me

# ---------------------------------------------------------------------------
# Flask / App
# ---------------------------------------------------------------------------
QSS_DEBUG=true
QSS_SECRET_KEY=change-this-secret-in-production
QSS_ENCRYPTION_KEY=
QSS_AUDIT_HASH_SECRET=change-this-audit-secret-in-production
QSS_SESSION_COOKIE_NAME=quantumshield_session
QSS_SESSION_IDLE_TIMEOUT_SECONDS=3600
QSS_FORCE_HTTPS=true
QSS_TRUST_PROXY_SSL=true
QSS_HSTS_SECONDS=31536000
# HTTP redirect daemon port — all plain HTTP on this port is 301'd to HTTPS
# Change this if port 5080 is already in use on your machine
QSS_HTTP_REDIRECT_PORT=5080
# Preferred lockout threshold env key (legacy fallback: QSS_MAX_LOGIN_ATTEMPTS)
QSS_INVALID_USERNAME_LOCKOUT_ATTEMPTS=5
QSS_MAX_LOGIN_ATTEMPTS=5
QSS_LOGIN_LOCKOUT_MINUTES=15
QSS_AUDIT_LOG_PAGE_SIZE=100

# ---------------------------------------------------------------------------
# Network binding
# ---------------------------------------------------------------------------
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
PORT=5000

# ---------------------------------------------------------------------------
# Database (preferred explicit keys)
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=change-me
# DB_PASSWORD=change-me
# DB_NAME=quantumshield

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=change-me
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=quantumshield

# Optional remote DB helper values used by scripts/remote_db_check.py
# and scripts/push_sql_to_remote.py
# REMOTE_MYSQL_HOST=
# REMOTE_MYSQL_PORT=3306
# REMOTE_MYSQL_USER=
# REMOTE_MYSQL_PASSWORD=
# REMOTE_MYSQL_DATABASE=

# ---------------------------------------------------------------------------
# SMTP / Email
# Use either MAIL_* or SMTP_* names. Both are supported.
# ---------------------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ---------------------------------------------------------------------------
# Admin bootstrap
# ---------------------------------------------------------------------------
QSS_ADMIN_USERNAME=admin
QSS_ADMIN_EMAIL=admin@localhost
QSS_ADMIN_EMPLOYEE_ID=ADMIN-001
QSS_ADMIN_PASSWORD=change-this-admin-password

# ---------------------------------------------------------------------------
# AI / Agent Configuration (examples)
# ---------------------------------------------------------------------------
# External LM server (optional). The app will POST to {AI_SERVER_URL}/v1/chat/completions
AI_SERVER_URL=http://127.0.0.1:1234
AI_SERVER_API_KEY=

# Server-side assistant defaults
QSS_AI_SYSTEM_PROMPT=You are the QuantumShield assistant. Provide concise, factual, and actionable security guidance based on any scan data supplied.
QSS_AI_USE_RAG=true
QSS_AI_MAX_TOKENS=512
QSS_AI_TEMPERATURE=0.2

# LLM client defaults (used when running a local model)
QSS_AI_MODEL_BACKEND=llama_cpp
QSS_AI_MODEL_PATH=models/llama-7b-q4_0.bin

# Optional external context endpoints for the assistant (comma-separated).
# Example: QSS_AI_EXTERNAL_CONTEXT_URLS=https://internal.service/api/summary,http://other/api/meta
QSS_AI_EXTERNAL_CONTEXT_URLS=
# Optional API key to send when fetching internal/external context endpoints.
# For safety the key is only sent to localhost or the configured FLASK_HOST:FLASK_PORT
# unless QSS_AI_EXTERNAL_CONTEXT_API_KEY_ALLOW_ALL is set to true.
QSS_AI_EXTERNAL_CONTEXT_API_KEY=
# If true, allow sending the above key to any URL in QSS_AI_EXTERNAL_CONTEXT_URLS
QSS_AI_EXTERNAL_CONTEXT_API_KEY_ALLOW_ALL=false

# Optional agent orchestrator example
QSS_AGENT_ENABLED=false
QSS_AGENT_BACKEND_URL=http://127.0.0.1:9000
QSS_AGENT_PORT=9000
QSS_AGENT_SYSTEM_PROMPT=You are an autonomous QuantumShield agent. When allowed, fetch scan data and metrics, summarize findings, and propose prioritized remediation steps.