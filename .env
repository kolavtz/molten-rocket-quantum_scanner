sql_server_url_with_port = localhost:3306
sql_user="db_local"
sql_password="test123@Abcd"

# ---------------------------------------------------------------------------
# Flask / App
# ---------------------------------------------------------------------------
QSS_DEBUG=true
QSS_SECRET_KEY=change-this-secret-in-production
QSS_ENCRYPTION_KEY=
QSS_AUDIT_HASH_SECRET=change-this-audit-secret-in-production
QSS_SESSION_COOKIE_NAME=quantumshield_session
QSS_SESSION_IDLE_TIMEOUT_SECONDS=3600
QSS_FORCE_HTTPS=true
QSS_TRUST_PROXY_SSL=true
QSS_HSTS_SECONDS=31536000
# HTTP redirect daemon port — all plain HTTP on this port is 301'd to HTTPS
# Change this if port 5080 is already in use on your machine
QSS_HTTP_REDIRECT_PORT=5080
# Preferred lockout threshold env key (legacy fallback: QSS_MAX_LOGIN_ATTEMPTS)
QSS_INVALID_USERNAME_LOCKOUT_ATTEMPTS=5
QSS_MAX_LOGIN_ATTEMPTS=5
QSS_LOGIN_LOCKOUT_MINUTES=15
QSS_AUDIT_LOG_PAGE_SIZE=100

# ---------------------------------------------------------------------------
# Network binding
# ---------------------------------------------------------------------------
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
PORT=5000

# ---------------------------------------------------------------------------
# Database (preferred explicit keys)
# ---------------------------------------------------------------------------
MYSQL_HOST=::1
MYSQL_PORT=3306
MYSQL_USER=db_local
MYSQL_PASSWORD=test123@Abcd
MYSQL_DATABASE=quantumshield

# ---------------------------------------------------------------------------
# SMTP / Email
# Use either MAIL_* or SMTP_* names. Both are supported.
# ---------------------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# ---------------------------------------------------------------------------
# Admin bootstrap
# ---------------------------------------------------------------------------
QSS_ADMIN_USERNAME=admin
QSS_ADMIN_EMAIL=admin@localhost
QSS_ADMIN_EMPLOYEE_ID=ADMIN-001
QSS_ADMIN_PASSWORD=Admin@12345678